---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import MenuSection from '../components/sections/MenuSection.astro';
import { menuCategories } from '../data/menu';
import { Image } from 'astro:assets';
import menuHeroImg from '../assets/photos/menu-hero-ingredients.jpg';
import spiceDecor from '../assets/decor/realistic/spice-spoons.png';
---

<BaseLayout title="Меню — PICCOLINO" description="Меню ресторана PICCOLINO: закуски, паста, основные блюда, десерты и вино.">
  <Header />
  <main class="menu-page" data-salt-progress>
    <section id="hero" class="menu-hero">
      <div class="menu-salt" aria-hidden="true"></div>
      <img class="menu-object menu-object-cutlery" src="/assets/decor/cutlery.svg" alt="" aria-hidden="true" loading="eager" data-parallax data-parallax-speed="0.045" data-parallax-rotate="2.2" />
      <Image class="menu-object menu-object-real menu-object-spice" src={spiceDecor} alt="" aria-hidden="true" loading="eager" data-parallax data-parallax-speed="0.035" data-parallax-rotate="-2" />
      <div class="container-site menu-hero-inner">
        <div class="menu-hero-copy">
          <img class="menu-copy-herb" src="/assets/decor/rosemary.svg" alt="" aria-hidden="true" loading="eager" data-parallax data-parallax-speed="0.03" data-parallax-rotate="1.8" />
          <a class="back-link" href="/" data-reveal="up">На главную</a>
          <h1 data-reveal="clip">Menu</h1>
          <p data-reveal="up" data-reveal-delay="150">
            Длинная ресторанная карта на темном фоне: паста ручной работы, открытый огонь, десерты и вина, которые собирают вечер.
          </p>
          <div class="hero-actions" data-reveal="up" data-reveal-delay="300">
            <Button href="#starters" variant="secondary" size="lg">Смотреть карту</Button>
            <Button href="/#reservation" variant="accent" size="lg">Забронировать</Button>
          </div>
        </div>
        <div class="menu-hero-plate" data-scroll-dish data-motion-rotate="7" data-reveal="scale">
          <Image src={menuHeroImg} alt="Итальянские ингредиенты для меню ресторана PICCOLINO" />
        </div>
      </div>
    </section>

    <div class="container-site menu-categories" data-menu-scroll-region>
      <div class="menu-scroll-line" aria-hidden="true" data-menu-scroll-line>
        <svg viewBox="0 0 1000 4800" preserveAspectRatio="none" focusable="false">
          <path
            class="menu-scroll-line-track"
            d="M 180 80 C 380 320 110 560 290 820 C 480 1100 790 960 690 1340 C 600 1680 190 1640 285 1980 C 380 2300 780 2200 710 2590 C 650 2920 300 2980 420 3320 C 540 3660 820 3540 760 3900 C 700 4220 380 4320 500 4650"
          />
          <path
            class="menu-scroll-line-progress"
            d="M 180 80 C 380 320 110 560 290 820 C 480 1100 790 960 690 1340 C 600 1680 190 1640 285 1980 C 380 2300 780 2200 710 2590 C 650 2920 300 2980 420 3320 C 540 3660 820 3540 760 3900 C 700 4220 380 4320 500 4650"
          />
        </svg>
      </div>
      {menuCategories.map((category, index) => (
        <MenuSection category={category} index={index} />
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .menu-page {
    --salt-progress: 0;
    --menu-bg-a: #f8efe1;
    --menu-bg-b: #efe1d0;
    --menu-bg-c: #e6d5c0;
    --menu-fg: #191715;
    --menu-muted: rgba(25, 23, 21, 0.66);
    --menu-border: rgba(45, 39, 34, 0.17);
    --menu-border-soft: rgba(45, 39, 34, 0.12);
    --menu-accent: #9e3f34;
    --menu-chip-bg: rgba(255, 250, 241, 0.62);
    --menu-salt-grain: rgba(92, 78, 65, 0.22);
    --menu-salt-grain-soft: rgba(92, 78, 65, 0.13);
    --menu-powder: rgba(255, 250, 241, 0.46);
    --menu-line-track: rgba(45, 39, 34, 0.16);
    --menu-line-progress: rgba(158, 63, 52, 0.54);
    --depth-opacity: 0.42;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 78% 10%, rgba(184, 74, 58, 0.12), transparent 30rem),
      linear-gradient(180deg, var(--menu-bg-a) 0%, var(--menu-bg-b) 48%, var(--menu-bg-c) 100%);
    color: var(--menu-fg);
  }

  :global([data-theme="dark"]) .menu-page {
    --menu-bg-a: #060708;
    --menu-bg-b: #090b0c;
    --menu-bg-c: #111719;
    --menu-fg: #f6efe4;
    --menu-muted: rgba(246, 239, 228, 0.66);
    --menu-border: rgba(246, 239, 228, 0.14);
    --menu-border-soft: rgba(246, 239, 228, 0.13);
    --menu-accent: #f0a28e;
    --menu-chip-bg: rgba(246, 239, 228, 0.06);
    --menu-salt-grain: rgba(246, 239, 228, 0.62);
    --menu-salt-grain-soft: rgba(246, 239, 228, 0.34);
    --menu-powder: rgba(246, 239, 228, 0.12);
    --menu-line-track: rgba(246, 239, 228, 0.13);
    --menu-line-progress: rgba(246, 239, 228, 0.45);
    --depth-opacity: 0.5;
    background:
      linear-gradient(180deg, var(--menu-bg-a) 0%, var(--menu-bg-b) 44%, var(--menu-bg-c) 100%);
  }

  .menu-page::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: calc(0.04 + var(--salt-progress) * 0.42);
    /* Organic salt/flour texture: irregular grains, no grid feel */
    background-image:
      /* Fine dust layer — tiny, dense, irregular */
      radial-gradient(ellipse 0.06rem 0.04rem at 17% 31%, var(--menu-salt-grain) 100%, transparent),
      radial-gradient(ellipse 0.05rem 0.07rem at 63% 23%, var(--menu-salt-grain-soft) 100%, transparent),
      radial-gradient(ellipse 0.07rem 0.04rem at 81% 77%, var(--menu-salt-grain) 100%, transparent),
      radial-gradient(ellipse 0.04rem 0.06rem at 44% 58%, var(--menu-salt-grain-soft) 100%, transparent),
      /* Medium grains — scattered, uneven spacing */
      radial-gradient(ellipse 0.14rem 0.09rem at 28% 14%, var(--menu-salt-grain) 100%, transparent),
      radial-gradient(ellipse 0.11rem 0.15rem at 71% 44%, var(--menu-salt-grain-soft) 100%, transparent),
      radial-gradient(ellipse 0.13rem 0.08rem at 52% 82%, var(--menu-salt-grain) 100%, transparent),
      radial-gradient(ellipse 0.09rem 0.12rem at 88% 29%, var(--menu-salt-grain-soft) 100%, transparent),
      /* Soft powder clouds — large, very low opacity gradient areas */
      radial-gradient(ellipse 28rem 18rem at 22% 62%, var(--menu-powder), transparent 70%),
      radial-gradient(ellipse 18rem 24rem at 78% 18%, var(--menu-powder), transparent 60%);
    background-size:
      3.7rem 5.2rem, 8.1rem 6.3rem, 5.8rem 9.4rem, 11.2rem 7.6rem,
      6.4rem 4.8rem, 13.6rem 9.2rem, 8.8rem 14rem, 10.4rem 6.8rem,
      100% 100%, 100% 100%;
    background-position:
      83% 8%, 9% 36%, 72% 82%, 38% 61%,
      57% 22%, 19% 74%, 86% 51%, 43% 9%,
      0% 0%, 0% 0%;
    background-repeat:
      repeat, repeat, repeat, repeat,
      repeat, repeat, repeat, repeat,
      no-repeat, no-repeat;
    clip-path: inset(calc((1 - var(--salt-progress)) * 20%) 0 0 0);
    mask-image:
      radial-gradient(ellipse at 68% 22%, black 0 18%, transparent 44%),
      radial-gradient(ellipse at 22% 64%, black 0 14%, transparent 38%),
      radial-gradient(ellipse at 74% 80%, black 0 10%, transparent 30%);
    transition: opacity 1200ms ease, clip-path 1400ms var(--ease-out);
  }

  /* Light theme: almost invisible, just faint warmth */
  :not(:global([data-theme="dark"])) .menu-page::before {
    opacity: calc(0.01 + var(--salt-progress) * 0.08);
  }

  :global(.menu-page [data-reveal]) {
    transition-duration: 1100ms, 1100ms, 1300ms, 1100ms;
  }

  :global(.menu-page [data-reveal="scale"]) {
    transition-duration: 1250ms, 1250ms, 1250ms, 1250ms;
  }

  .menu-hero,
  .menu-categories {
    position: relative;
    z-index: 1;
  }

  .menu-hero {
    min-height: 100svh;
    display: grid;
    align-items: center;
    padding-top: 6rem;
    overflow: hidden;
  }

  .menu-salt {
    position: absolute;
    inset: 0;
    opacity: calc(0.18 + var(--salt-progress) * 0.5);
    background:
      radial-gradient(circle at 74% 34%, var(--menu-salt-grain) 0 0.06rem, transparent 0.11rem) 0 0 / 2.6rem 3.4rem,
      radial-gradient(circle at 78% 36%, var(--menu-salt-grain-soft) 0 0.08rem, transparent 0.13rem) 0 0 / 5.8rem 4.2rem,
      radial-gradient(ellipse at 72% 38%, var(--menu-powder), transparent 54%);
    clip-path: inset(calc((1 - var(--salt-progress)) * 22%) 0 0 0);
    mask-image: radial-gradient(ellipse at 75% 38%, black 0 26%, transparent 64%);
    transition: opacity 1300ms ease, clip-path 1500ms var(--ease-out);
  }

  .menu-hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.72fr);
    gap: clamp(2rem, 7vw, 8rem);
    align-items: center;
  }

  .back-link {
    color: var(--menu-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 1rem 0 0;
    color: var(--menu-fg);
    font-size: clamp(6rem, 18vw, 16rem);
    line-height: 0.78;
  }

  .menu-hero p {
    max-width: 45rem;
    margin: 1.6rem 0 0;
    color: var(--menu-muted);
    font-size: clamp(1.05rem, 2vw, 1.45rem);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.2rem;
  }

  :global([data-theme="dark"] .menu-page .btn-secondary) {
    color: #f6efe4;
    border-color: rgba(246, 239, 228, 0.36);
  }

  .menu-hero-plate {
    position: relative;
    aspect-ratio: 1;
    transform: translateY(var(--dish-motion-y, 0px)) rotate(var(--dish-motion-rotate, 0deg)) scale(var(--dish-motion-scale, 1));
    will-change: transform;
  }

  .menu-hero-plate::before {
    content: '';
    position: absolute;
    inset: 11%;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.55);
    filter: blur(34px);
    transform: translateY(12%);
  }

  .menu-hero-plate img {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    box-shadow: 0 2rem 6rem rgba(0, 0, 0, 0.62);
  }

  .menu-object {
    position: absolute;
    pointer-events: none;
    z-index: 1;
    object-fit: contain;
    opacity: var(--depth-opacity);
    animation: menu-object-float 8s ease-in-out infinite;
  }

  .menu-object-cutlery {
    right: clamp(1rem, 5vw, 5rem);
    top: 14%;
    width: clamp(6rem, 10vw, 9rem);
    height: auto;
    transform: translate3d(0, var(--parallax-y, 0px), 0) rotate(calc(17deg + var(--parallax-rotate, 0deg)));
    opacity: calc(var(--depth-opacity) * 0.86);
    filter: contrast(1.18) brightness(0.92) drop-shadow(0 1rem 1.4rem rgba(0, 0, 0, 0.18));
  }

  .menu-object-real {
    height: auto;
    object-fit: contain;
  }

  .menu-object-spice {
    right: clamp(8rem, 18vw, 18rem);
    bottom: 6%;
    width: clamp(5rem, 8vw, 7.5rem);
    transform: translate3d(0, var(--parallax-y, 0px), 0) rotate(calc(-12deg + var(--parallax-rotate, 0deg)));
    opacity: 0.32;
    filter: saturate(0.88) contrast(0.92) drop-shadow(0 1rem 1.4rem rgba(0, 0, 0, 0.16));
    animation-delay: -3s;
  }

  :global([data-theme="dark"]) .menu-object-cutlery {
    opacity: 0.58;
    filter: invert(1) sepia(0.12) saturate(0.55) brightness(1.08) drop-shadow(0 0 1.1rem rgba(246, 239, 228, 0.14)) drop-shadow(0 1rem 1.6rem rgba(0, 0, 0, 0.28));
  }

  :global([data-theme="dark"]) .menu-object-real {
    opacity: 0.46;
    filter: saturate(0.82) brightness(0.86) contrast(1.02) drop-shadow(0 0 1.1rem rgba(246, 239, 228, 0.08)) drop-shadow(0 1rem 1.6rem rgba(0, 0, 0, 0.3));
  }

  .menu-hero-copy {
    position: relative;
  }

  .menu-copy-herb {
    position: absolute;
    pointer-events: none;
    right: clamp(0rem, 6vw, 4rem);
    top: -2.6rem;
    z-index: -1;
    width: clamp(4.8rem, 7vw, 7rem);
    height: auto;
    opacity: calc(var(--depth-opacity) * 0.78);
    transform: translate3d(0, var(--parallax-y, 0px), 0) rotate(calc(31deg + var(--parallax-rotate, 0deg)));
    filter: drop-shadow(0 1rem 1.5rem rgba(0, 0, 0, 0.16));
  }

  :global([data-theme="dark"]) .menu-copy-herb {
    filter: invert(0.92) sepia(0.18) saturate(0.64) opacity(0.78) drop-shadow(0 1rem 1.6rem rgba(0, 0, 0, 0.28));
  }

  @keyframes menu-object-float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -0.75rem; }
  }

  .menu-categories {
    isolation: isolate;
    padding-bottom: clamp(4rem, 9vw, 8rem);
  }

  .menu-scroll-line {
    position: absolute;
    inset: 0 clamp(1.25rem, 5vw, 5rem) 0 clamp(1.25rem, 5vw, 5rem);
    z-index: 0;
    pointer-events: none;
    opacity: 0.88;
  }

  .menu-scroll-line svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .menu-scroll-line path {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .menu-scroll-line-track {
    stroke: var(--menu-line-track);
    stroke-width: 1.2;
    stroke-dasharray: 2 18;
  }

  .menu-scroll-line-progress {
    stroke: var(--menu-line-progress);
    stroke-width: 2.5;
    filter: drop-shadow(0 0 0.6rem rgba(158, 63, 52, 0.22)) drop-shadow(0 0.5rem 1.4rem rgba(158, 63, 52, 0.14));
    transition: stroke 240ms ease;
  }

  :global([data-theme="dark"]) .menu-scroll-line-progress {
    filter: drop-shadow(0 0 0.8rem rgba(240, 162, 142, 0.18)) drop-shadow(0 0.5rem 1.4rem rgba(246, 239, 228, 0.08));
  }

  .menu-categories :global(.menu-category) {
    z-index: 1;
  }

  @media (max-width: 880px) {
    .menu-hero { min-height: auto; padding-block: 8rem 4rem; }
    .menu-hero-inner { grid-template-columns: 1fr; }
    .menu-hero-plate { width: min(100%, 18rem); margin-inline: auto; }
    .hero-actions :global(.btn) { width: 100%; }
    .menu-object-cutlery,
    .menu-object-real { display: none; }
    .menu-copy-herb { right: 0; top: -1.8rem; width: clamp(4rem, 18vw, 5.2rem); }
    .menu-scroll-line {
      inset: 1rem auto 0 clamp(0.8rem, 3vw, 1.25rem);
      width: clamp(3rem, 15vw, 5.5rem);
      opacity: 0.42;
    }

    .menu-scroll-line-track { stroke-width: 0.9; }
    .menu-scroll-line-progress { stroke-width: 1.4; }
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-object,
    .menu-page::before,
    .menu-salt,
    .menu-scroll-line-progress {
      animation: none;
      transition: none;
    }

    .menu-scroll-line-progress {
      stroke-dashoffset: 0 !important;
    }
  }
</style>
