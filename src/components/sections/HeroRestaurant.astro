---import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import heroImg from '../../assets/photos/home-hero-restaurant.jpg';
import wineImg from '../../assets/photos/menu-wine.jpg';
import tomatoDecor from '../../assets/decor/realistic/tomatoes-vine.png';
---

<section id="hero" class="hero-restaurant">
  <div class="hero-media">
    <Image
      src={heroImg}
      alt="Теплый зал итальянского ресторана с сервированными столами"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="hero-shade" aria-hidden="true"></div>
  <Image
    class="hero-tomato-decor"
    src={tomatoDecor}
    alt=""
    aria-hidden="true"
    loading="eager"
    data-parallax
    data-parallax-speed="0.04"
    data-parallax-rotate="-2.5"
  />

  <div class="container-site hero-inner">
    <div class="hero-copy">
      <h1 data-reveal="clip">PICCOLINO</h1>
      <div class="hero-copy-lower">
        <div class="hero-copy-body">
          <p class="hero-subtitle" data-reveal="up" data-reveal-delay="150">
            Современная итальянская кухня, камерная атмосфера и вкус, который хочется продлить.
          </p>
          <div class="hero-actions" data-reveal="up" data-reveal-delay="300">
            <Button href="/menu" variant="primary" size="lg">Посмотреть меню</Button>
            <Button href="#reservation" variant="secondary" size="lg">Забронировать стол</Button>
          </div>
        </div>

        <figure
          class="hero-editorial-card"
          data-reveal="scale"
          data-reveal-delay="420"
          data-parallax
          data-parallax-speed="0.055"
          data-parallax-rotate="2.4"
        >
          <Image
            src={wineImg}
            alt="Бокалы красного вина за ресторанным столом"
            loading="eager"
          />
        </figure>
      </div>
    </div>

    <div class="hero-notes" aria-label="Особенности PICCOLINO">
      <button class="hero-note is-active" type="button" data-reveal="up" data-reveal-delay="450">
        <span class="note-kicker">01</span>
        <span class="note-title">паста ручной работы</span>
      </button>
      <button class="hero-note" type="button" data-reveal="up" data-reveal-delay="560">
        <span class="note-kicker">02</span>
        <span class="note-title">вечерний зал</span>
      </button>
      <button class="hero-note" type="button" data-reveal="up" data-reveal-delay="670">
        <span class="note-kicker">03</span>
        <span class="note-title">винная карта</span>
      </button>
    </div>
  </div>
</section>

<style>
  .hero-restaurant {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: end;
    overflow: hidden;
    background: var(--color-hero);
    color: #fffaf1;
  }

  .hero-tomato-decor {
    position: absolute;
    pointer-events: none;
    z-index: 2;
    right: clamp(0.5rem, 3vw, 3rem);
    bottom: clamp(9rem, 20vw, 20rem);
    width: clamp(5rem, 8.5vw, 8.5rem);
    height: auto;
    object-fit: contain;
    opacity: 0.62;
    filter: saturate(1.15) contrast(1.06) drop-shadow(0 1.2rem 2.4rem rgba(0,0,0,0.44));
    animation: hero-tomato-float 11s ease-in-out infinite;
    transform: rotate(-14deg);
  }

  @keyframes hero-tomato-float {
    0%, 100% { translate: 0 0; rotate: -14deg; }
    50% { translate: 0.3rem -0.7rem; rotate: -11deg; }
  }

  :global([data-theme="dark"]) .hero-tomato-decor {
    opacity: 0.36;
    filter: saturate(0.9) brightness(0.82) contrast(1.04) drop-shadow(0 0 1rem rgba(246,239,228,0.06)) drop-shadow(0 1rem 2rem rgba(0,0,0,0.42));
  }

  .hero-restaurant::after {
    content: '';
    position: absolute;
    right: clamp(1rem, 8vw, 8rem);
    bottom: clamp(8rem, 17vw, 17rem);
    width: clamp(9rem, 22vw, 22rem);
    aspect-ratio: 1;
    border: 1px solid rgba(255, 250, 241, 0.18);
    border-radius: 50%;
    opacity: 0.48;
    transform: translate3d(0, var(--hero-accent-lift, 0), 0);
    transition: opacity 260ms ease, transform 260ms ease, border-color 260ms ease;
    pointer-events: none;
  }

  .hero-restaurant:has(.hero-note:hover)::after,
  .hero-restaurant:has(.hero-note:focus-visible)::after {
    --hero-accent-lift: -0.7rem;
    opacity: 0.78;
    border-color: rgba(240, 162, 142, 0.52);
  }

  .hero-media,
  .hero-shade {
    position: absolute;
    inset: 0;
  }

  .hero-media {
    z-index: 0;
    overflow: hidden;
  }

  .hero-shade {
    z-index: 1;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.03);
  }

  .hero-shade {
    background:
      linear-gradient(90deg, rgba(5, 9, 10, 0.74), rgba(5, 9, 10, 0.28) 54%, rgba(5, 9, 10, 0.64)),
      linear-gradient(180deg, rgba(5, 9, 10, 0.18), rgba(5, 9, 10, 0.68));
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 7rem;
    padding-bottom: clamp(2rem, 7vw, 5rem);
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    max-width: min(100%, 82rem);
  }

  h1 {
    margin: 0;
    max-width: 100%;
    padding-right: clamp(0.08em, 1.2vw, 0.14em);
    font-size: min(clamp(4.2rem, 15.5vw, 13.7rem), calc((100vw - clamp(3rem, 10vw, 10rem)) / 5.65));
    color: #fffaf1;
    text-transform: uppercase;
    line-height: 0.84;
    text-shadow: 0 1rem 4rem rgba(0, 0, 0, 0.36);
    overflow: visible;
  }

  h1[data-reveal="clip"] {
    transition-duration: 1400ms;
    transition-timing-function: var(--ease-out);
  }

  .hero-subtitle {
    max-width: 43rem;
    margin: 0;
    color: rgba(255, 250, 241, 0.82);
    font-size: clamp(1.05rem, 2.2vw, 1.55rem);
    line-height: 1.55;
  }

  .hero-copy-lower {
    display: grid;
    grid-template-columns: minmax(0, 43rem) minmax(16rem, 26rem);
    gap: clamp(1.5rem, 4vw, 4.5rem);
    align-items: end;
    width: min(100%, 82rem);
    margin-top: clamp(1.25rem, 2.6vw, 2.2rem);
  }

  .hero-copy-body {
    min-width: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.2rem;
  }

  .hero-actions :global(.btn-secondary) {
    color: #fffaf1;
    border-color: rgba(255, 250, 241, 0.42);
  }

  .hero-editorial-card {
    --hero-card-base-rotate: 1.7deg;
    --parallax-y: 0px;
    --parallax-rotate: 0deg;
    position: relative;
    z-index: 1;
    align-self: center;
    width: min(100%, 26rem);
    aspect-ratio: 0.78;
    margin: 0 0 0.25rem;
    overflow: hidden;
    border: 1px solid rgba(255, 250, 241, 0.22);
    border-radius: 42% 58% 44% 56% / 36% 42% 58% 64%;
    background: rgba(255, 250, 241, 0.08);
    box-shadow:
      0 2rem 5rem rgba(0, 0, 0, 0.38),
      0 0.7rem 1.8rem rgba(0, 0, 0, 0.24);
    transform: translate3d(0, calc(1.8rem + var(--parallax-y)), 0) rotate(calc(var(--hero-card-base-rotate) + var(--parallax-rotate)));
    transform-origin: 52% 54%;
    transition:
      opacity 1200ms var(--ease-out),
      transform 1200ms var(--ease-out),
      filter 1200ms var(--ease-out),
      border-color 260ms ease;
    will-change: transform;
  }

  .hero-editorial-card::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(6, 7, 8, 0.08), rgba(6, 7, 8, 0.28)),
      radial-gradient(ellipse at 22% 12%, rgba(255, 250, 241, 0.18), transparent 44%);
    mix-blend-mode: soft-light;
  }

  .hero-editorial-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 34% 50%;
    transform: scale(1.04);
  }

  .hero-editorial-card[data-reveal].is-visible {
    opacity: 1;
    filter: blur(0);
    transform: translate3d(0, var(--parallax-y), 0) rotate(calc(var(--hero-card-base-rotate) + var(--parallax-rotate)));
  }

  .hero-notes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: clamp(4rem, 13vw, 9rem);
    padding-top: 1.1rem;
    border-top: 1px solid rgba(255, 250, 241, 0.24);
    font-size: 0.73rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-note {
    position: relative;
    min-height: 5.2rem;
    display: grid;
    align-content: end;
    gap: 0.55rem;
    overflow: hidden;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: rgba(255, 250, 241, 0.62);
    padding: 0 0.25rem 0.15rem 0;
    text-align: left;
    text-transform: uppercase;
    letter-spacing: inherit;
    transform: translate3d(0, 0, 0);
    transition: color 220ms ease, transform 220ms ease;
  }

  .hero-note::before,
  .hero-note::after {
    content: '';
    position: absolute;
    left: 0;
    pointer-events: none;
  }

  .hero-note::before {
    right: 0;
    bottom: 0;
    height: 1px;
    background: rgba(255, 250, 241, 0.22);
  }

  .hero-note::after {
    bottom: 0;
    width: 100%;
    height: 1px;
    background: #f0a28e;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 520ms var(--ease-out);
  }

  .note-kicker {
    color: rgba(240, 162, 142, 0.76);
    font-size: 0.66rem;
    font-weight: 700;
    transform: translateY(0.2rem);
    transition: transform 220ms ease, color 220ms ease;
  }

  .note-title {
    position: relative;
    display: inline-block;
    width: fit-content;
  }

  .note-title::after {
    content: '';
    position: absolute;
    inset: auto 0 -0.35rem 0;
    height: 0.22rem;
    border-radius: 999px;
    background: rgba(240, 162, 142, 0.16);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 260ms ease;
  }

  .hero-note:hover,
  .hero-note:focus-visible,
  .hero-note.is-active {
    color: #fffaf1;
    transform: translateY(-0.35rem);
  }

  .hero-note:hover::after,
  .hero-note:focus-visible::after,
  .hero-note.is-active::after,
  .hero-note:hover .note-title::after,
  .hero-note:focus-visible .note-title::after,
  .hero-note.is-active .note-title::after {
    transform: scaleX(1);
  }

  .hero-note:hover .note-kicker,
  .hero-note:focus-visible .note-kicker,
  .hero-note.is-active .note-kicker {
    color: #f0a28e;
    transform: translateY(0);
  }

  .hero-note:focus-visible {
    outline: 2px solid rgba(240, 162, 142, 0.7);
    outline-offset: 4px;
  }

  @keyframes hero-note-float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -0.28rem; }
  }

  .hero-note.is-active {
    animation: hero-note-float 5.8s ease-in-out infinite;
  }

  @media (max-width: 700px) {
    .hero-restaurant { min-height: 92svh; }
    .hero-shade {
      background:
        linear-gradient(180deg, rgba(5, 9, 10, 0.35), rgba(5, 9, 10, 0.78)),
        linear-gradient(90deg, rgba(5, 9, 10, 0.62), rgba(5, 9, 10, 0.28));
    }
    h1 {
      padding-right: 0.08em;
      font-size: clamp(2.85rem, 12vw, 4.5rem);
      line-height: 0.88;
    }
    .hero-copy-lower { grid-template-columns: 1fr; }
    .hero-editorial-card {
      width: min(70vw, 16rem);
      justify-self: end;
      margin-top: 1.4rem;
      margin-right: 0.25rem;
      opacity: 0.88;
    }
    .hero-tomato-decor { display: none; }
    .hero-actions { align-items: stretch; }
    .hero-actions :global(.btn) { width: 100%; }
    .hero-notes { grid-template-columns: 1fr; gap: 0.65rem; margin-top: 3rem; }
    .hero-note {
      min-height: 3.4rem;
      color: rgba(255, 250, 241, 0.84);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-note,
    .hero-note.is-active,
    .hero-editorial-card {
      animation: none;
      transition: none;
    }

    .hero-editorial-card,
    .hero-editorial-card[data-reveal].is-visible {
      transform: rotate(var(--hero-card-base-rotate));
    }
  }
</style>

<script>
  function initHeroNotes() {
    const notes = Array.from(document.querySelectorAll<HTMLButtonElement>('.hero-note'));
    if (!notes.length) return;

    notes.forEach((note) => {
      if (note.dataset.heroNoteReady === 'true') return;
      note.dataset.heroNoteReady = 'true';
      const activate = () => {
        notes.forEach((item) => item.classList.toggle('is-active', item === note));
      };
      note.addEventListener('mouseenter', activate);
      note.addEventListener('focus', activate);
      note.addEventListener('click', activate);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroNotes, { once: true });
  } else {
    initHeroNotes();
  }
  document.addEventListener('astro:page-load', initHeroNotes);
</script>
