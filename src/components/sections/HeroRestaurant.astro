---
import Button from '../ui/Button.astro';
---

<section id="hero" class="hero-restaurant">
  <div class="hero-media" aria-hidden="true">
    <img
      src="https://images.unsplash.com/photo-1514933651103-005eec06c04b?auto=format&fit=crop&w=2200&q=88"
      alt=""
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="hero-shade" aria-hidden="true"></div>

  <div class="container-site hero-inner">
    <div class="hero-copy">
      <h1 data-reveal="clip">PICCOLINO</h1>
      <p class="hero-subtitle" data-reveal="up" data-reveal-delay="150">
        Современная итальянская кухня, камерная атмосфера и вкус, который хочется продлить.
      </p>
      <div class="hero-actions" data-reveal="up" data-reveal-delay="300">
        <Button href="/menu" variant="primary" size="lg">Посмотреть меню</Button>
        <Button href="#reservation" variant="secondary" size="lg">Забронировать стол</Button>
      </div>
    </div>

    <div class="hero-notes" aria-label="Особенности PICCOLINO">
      <button class="hero-note is-active" type="button" data-reveal="up" data-reveal-delay="450">
        <span class="note-kicker">01</span>
        <span class="note-title">паста ручной работы</span>
      </button>
      <button class="hero-note" type="button" data-reveal="up" data-reveal-delay="560">
        <span class="note-kicker">02</span>
        <span class="note-title">вечерний зал</span>
      </button>
      <button class="hero-note" type="button" data-reveal="up" data-reveal-delay="670">
        <span class="note-kicker">03</span>
        <span class="note-title">винная карта</span>
      </button>
    </div>
  </div>
</section>

<style>
  .hero-restaurant {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: end;
    overflow: hidden;
    background: var(--color-hero);
    color: #fffaf1;
  }

  .hero-restaurant::after {
    content: '';
    position: absolute;
    right: clamp(1rem, 8vw, 8rem);
    bottom: clamp(8rem, 17vw, 17rem);
    width: clamp(9rem, 22vw, 22rem);
    aspect-ratio: 1;
    border: 1px solid rgba(255, 250, 241, 0.18);
    border-radius: 50%;
    opacity: 0.48;
    transform: translate3d(0, var(--hero-accent-lift, 0), 0);
    transition: opacity 260ms ease, transform 260ms ease, border-color 260ms ease;
    pointer-events: none;
  }

  .hero-restaurant:has(.hero-note:hover)::after,
  .hero-restaurant:has(.hero-note:focus-visible)::after {
    --hero-accent-lift: -0.7rem;
    opacity: 0.78;
    border-color: rgba(240, 162, 142, 0.52);
  }

  .hero-media,
  .hero-shade {
    position: absolute;
    inset: 0;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.03);
  }

  .hero-shade {
    background:
      linear-gradient(90deg, rgba(5, 9, 10, 0.74), rgba(5, 9, 10, 0.28) 54%, rgba(5, 9, 10, 0.64)),
      linear-gradient(180deg, rgba(5, 9, 10, 0.18), rgba(5, 9, 10, 0.68));
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-top: 7rem;
    padding-bottom: clamp(2rem, 7vw, 5rem);
  }

  .hero-copy {
    max-width: 76rem;
  }

  h1 {
    margin: 0;
    max-width: 100%;
    padding-right: 0.05em;
    font-size: clamp(4.2rem, 16.2vw, 14.6rem);
    color: #fffaf1;
    text-transform: uppercase;
    line-height: 0.84;
    text-shadow: 0 1rem 4rem rgba(0, 0, 0, 0.36);
    overflow: visible;
  }

  .hero-subtitle {
    max-width: 43rem;
    margin: 1.5rem 0 0;
    color: rgba(255, 250, 241, 0.82);
    font-size: clamp(1.05rem, 2.2vw, 1.55rem);
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.2rem;
  }

  .hero-actions :global(.btn-secondary) {
    color: #fffaf1;
    border-color: rgba(255, 250, 241, 0.42);
  }

  .hero-notes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: clamp(4rem, 13vw, 9rem);
    padding-top: 1.1rem;
    border-top: 1px solid rgba(255, 250, 241, 0.24);
    font-size: 0.73rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-note {
    position: relative;
    min-height: 5.2rem;
    display: grid;
    align-content: end;
    gap: 0.55rem;
    overflow: hidden;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: rgba(255, 250, 241, 0.62);
    padding: 0 0.25rem 0.15rem 0;
    text-align: left;
    text-transform: uppercase;
    letter-spacing: inherit;
    transform: translate3d(0, 0, 0);
    transition: color 220ms ease, transform 220ms ease;
  }

  .hero-note::before,
  .hero-note::after {
    content: '';
    position: absolute;
    left: 0;
    pointer-events: none;
  }

  .hero-note::before {
    right: 0;
    bottom: 0;
    height: 1px;
    background: rgba(255, 250, 241, 0.22);
  }

  .hero-note::after {
    bottom: 0;
    width: 100%;
    height: 1px;
    background: #f0a28e;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 520ms var(--ease-out);
  }

  .note-kicker {
    color: rgba(240, 162, 142, 0.76);
    font-size: 0.66rem;
    font-weight: 700;
    transform: translateY(0.2rem);
    transition: transform 220ms ease, color 220ms ease;
  }

  .note-title {
    position: relative;
    display: inline-block;
    width: fit-content;
  }

  .note-title::after {
    content: '';
    position: absolute;
    inset: auto 0 -0.35rem 0;
    height: 0.22rem;
    border-radius: 999px;
    background: rgba(240, 162, 142, 0.16);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 260ms ease;
  }

  .hero-note:hover,
  .hero-note:focus-visible,
  .hero-note.is-active {
    color: #fffaf1;
    transform: translateY(-0.35rem);
  }

  .hero-note:hover::after,
  .hero-note:focus-visible::after,
  .hero-note.is-active::after,
  .hero-note:hover .note-title::after,
  .hero-note:focus-visible .note-title::after,
  .hero-note.is-active .note-title::after {
    transform: scaleX(1);
  }

  .hero-note:hover .note-kicker,
  .hero-note:focus-visible .note-kicker,
  .hero-note.is-active .note-kicker {
    color: #f0a28e;
    transform: translateY(0);
  }

  .hero-note:focus-visible {
    outline: 2px solid rgba(240, 162, 142, 0.7);
    outline-offset: 4px;
  }

  @keyframes hero-note-float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -0.28rem; }
  }

  .hero-note.is-active {
    animation: hero-note-float 5.8s ease-in-out infinite;
  }

  @media (max-width: 700px) {
    .hero-restaurant { min-height: 92svh; }
    .hero-shade {
      background:
        linear-gradient(180deg, rgba(5, 9, 10, 0.35), rgba(5, 9, 10, 0.78)),
        linear-gradient(90deg, rgba(5, 9, 10, 0.62), rgba(5, 9, 10, 0.28));
    }
    h1 {
      padding-right: 0.08em;
      font-size: clamp(3.75rem, 21.5vw, 7rem);
      line-height: 0.88;
    }
    .hero-actions { align-items: stretch; }
    .hero-actions :global(.btn) { width: 100%; }
    .hero-notes { grid-template-columns: 1fr; gap: 0.65rem; margin-top: 3rem; }
    .hero-note {
      min-height: 3.4rem;
      color: rgba(255, 250, 241, 0.84);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-note,
    .hero-note.is-active {
      animation: none;
      transition: none;
      transform: none;
    }
  }
</style>

<script>
  function initHeroNotes() {
    const notes = Array.from(document.querySelectorAll<HTMLButtonElement>('.hero-note'));
    if (!notes.length) return;

    notes.forEach((note) => {
      if (note.dataset.heroNoteReady === 'true') return;
      note.dataset.heroNoteReady = 'true';
      const activate = () => {
        notes.forEach((item) => item.classList.toggle('is-active', item === note));
      };
      note.addEventListener('mouseenter', activate);
      note.addEventListener('focus', activate);
      note.addEventListener('click', activate);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroNotes, { once: true });
  } else {
    initHeroNotes();
  }
  document.addEventListener('astro:page-load', initHeroNotes);
</script>
