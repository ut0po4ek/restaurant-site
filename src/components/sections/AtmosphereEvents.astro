---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import wineEveningImg from '../../assets/photos/wine-evening.jpg';
import basilDecor from '../../assets/decor/realistic/basil-leaves.png';
import mushroomDecor from '../../assets/decor/realistic/champignon-mushrooms.png';
---

<section id="events" class="events-section section-padding">
  <div class="container-site events-grid">
    <div class="event-image" data-reveal="left">
      <Image src={wineEveningImg} alt="Бутылки вина и камерная атмосфера винного вечера" loading="lazy" />
    </div>
    <div class="event-copy" data-reveal="right">
      <Image class="event-photo-decor event-decor-basil" src={basilDecor} alt="" aria-hidden="true" loading="lazy" data-parallax data-parallax-speed="0.04" data-parallax-rotate="2" />
      <Image class="event-photo-decor event-decor-mushroom" src={mushroomDecor} alt="" aria-hidden="true" loading="lazy" data-parallax data-parallax-speed="0.025" data-parallax-rotate="-1.5" />
      <span class="eyebrow-line">События</span>
      <h2>Винные ужины и камерные встречи</h2>
      <p>
        Раз в месяц мы собираем гостей за длинным столом: сезонные блюда, небольшие партии вина и спокойный разговор с шефом о вкусе, регионе и времени года.
      </p>
      <div class="event-card">
        <span>Ближайший ужин</span>
        <strong>Пятница, 20:00</strong>
        <p>Тоскана: красные вина, мясо на гриле и домашняя паста.</p>
      </div>
      <Button href="#reservation" variant="secondary" size="lg">Забронировать место</Button>
    </div>
  </div>
</section>

<style>
  .events-section {
    background: var(--color-bg-dark);
    color: #f6efe4;
  }

  .events-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(22rem, 0.88fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: stretch;
  }

  .event-image {
    min-height: clamp(34rem, 48vw, 45rem);
    overflow: hidden;
    border: 1px solid rgba(246, 239, 228, 0.13);
  }

  .event-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 52%;
    transform: scale(1.02);
  }

  .event-copy {
    position: relative;
    align-self: center;
  }

  .event-photo-decor {
    position: absolute;
    pointer-events: none;
    height: auto;
    object-fit: contain;
    filter: saturate(0.74) brightness(0.78) contrast(1.05) drop-shadow(0 0 1rem rgba(246, 239, 228, 0.1)) drop-shadow(0 1.2rem 1.8rem rgba(0, 0, 0, 0.3));
  }

  .event-decor-basil {
    right: clamp(0rem, 5vw, 4rem);
    top: -3.5rem;
    width: clamp(5rem, 7.5vw, 7rem);
    opacity: 0.52;
    filter: saturate(1.1) contrast(1.06) drop-shadow(0 1rem 1.8rem rgba(0,0,0,0.42));
    transform: translate3d(0, var(--parallax-y, 0px), 0) rotate(calc(14deg + var(--parallax-rotate, 0deg)));
  }

  .event-decor-mushroom {
    left: clamp(0rem, 3vw, 2rem);
    bottom: -1.5rem;
    width: clamp(5.5rem, 8vw, 7rem);
    opacity: 0.44;
    filter: saturate(0.82) brightness(0.76) contrast(1.06) drop-shadow(0 1rem 1.8rem rgba(0,0,0,0.4));
    transform: translate3d(0, var(--parallax-y, 0px), 0) rotate(calc(-8deg + var(--parallax-rotate, 0deg)));
    animation: mushroom-float 11s ease-in-out infinite;
    animation-delay: -5s;
  }

  @keyframes mushroom-float {
    0%, 100% { translate: 0 0; }
    50% { translate: -0.3rem -0.6rem; }
  }

  .eyebrow-line { color: #f0a28e; }

  h2 {
    margin: 1rem 0 0;
    color: #f6efe4;
    font-size: clamp(3rem, 7vw, 6.2rem);
  }

  .event-copy > p {
    max-width: 40rem;
    margin: 1.4rem 0 0;
    color: rgba(246, 239, 228, 0.70);
  }

  .event-card {
    margin: 2rem 0;
    padding: 1.4rem 0;
    border-block: 1px solid rgba(246, 239, 228, 0.14);
  }

  .event-card span {
    display: block;
    color: rgba(246, 239, 228, 0.48);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .event-card strong {
    display: block;
    margin-top: 0.5rem;
    color: #f6efe4;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.2rem;
    font-weight: 500;
  }

  .event-card p {
    margin: 0.4rem 0 0;
    color: rgba(246, 239, 228, 0.64);
  }

  :global(.events-section .btn-secondary) {
    color: #f6efe4;
    border-color: rgba(246, 239, 228, 0.34);
  }

  @media (max-width: 900px) {
    .events-grid { grid-template-columns: 1fr; }
    .event-image {
      min-height: clamp(22rem, 62vw, 32rem);
      order: 2;
    }
    .event-copy { order: 1; }
    .event-decor-basil,
    .event-decor-mushroom { display: none; }
  }
</style>
