---
import { Image } from 'astro:assets';
import ScrollTextReveal from './ScrollTextReveal.astro';
import saladImg from '../../assets/photos/salt-salad.jpg';
import steakImg from '../../assets/photos/salt-steak.jpg';
import dessertImg from '../../assets/photos/salt-dessert.jpg';
---

<section id="atmosphere" class="salt-story section-padding" data-salt-progress>
  <div class="salt-grain" aria-hidden="true"></div>
  <div class="container-site salt-inner">
    <div class="salt-copy">
      <span class="eyebrow-line" data-reveal="up">Темный зал</span>
      <div class="salt-heading-stack">
        <h2 data-reveal="up" data-reveal-delay="150">Соль, огонь и глубокий вечерний фон</h2>
        <ScrollTextReveal
          class="salt-text"
          text="Меню построено вокруг свежих ингредиентов, открытого огня и классических итальянских сочетаний. На темном фоне вкус становится точнее: хруст хлеба, дым гриля, плотность соуса и тихий блеск бокала."
        />
      </div>
    </div>
    <div class="salt-plates" aria-label="Блюда на темном фоне">
      <Image class="plate plate-one" data-scroll-rotate="14" src={saladImg} alt="Салат на круглой тарелке" loading="lazy" />
      <Image class="plate plate-two" data-scroll-rotate="16" data-scroll-direction="reverse" src={steakImg} alt="Стейк с овощами на тарелке" loading="lazy" />
      <Image class="plate plate-three" data-scroll-rotate="12" src={dessertImg} alt="Десерт с ягодами на тарелке" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .salt-story {
    --salt-progress: 0;
    --salt-bg-a: rgba(247, 241, 231, 0.94);
    --salt-bg-b: rgba(235, 224, 211, 0.98);
    --salt-text: var(--color-fg);
    --salt-text-muted: var(--color-fg-muted);
    --salt-accent: var(--color-accent-dark);
    --salt-grain-a: rgba(25, 23, 21, 0.12);
    --salt-grain-b: rgba(184, 74, 58, 0.08);
    position: relative;
    overflow: hidden;
    min-height: 46rem;
    background:
      linear-gradient(180deg, var(--salt-bg-a), var(--salt-bg-b)),
      var(--color-bg);
    color: var(--salt-text);
  }

  :global([data-theme="dark"]) .salt-story {
    --salt-bg-a: rgba(6, 7, 8, 0.94);
    --salt-bg-b: rgba(6, 7, 8, 0.98);
    --salt-text: #f6efe4;
    --salt-text-muted: rgba(246, 239, 228, 0.70);
    --salt-accent: #f0a28e;
    --salt-grain-a: rgba(246, 239, 228, 0.16);
    --salt-grain-b: rgba(240, 162, 142, 0.08);
  }

  .salt-grain {
    position: absolute;
    inset: 0;
    opacity: calc(0.08 + var(--salt-progress) * 0.24);
    clip-path: inset(calc((1 - var(--salt-progress)) * 18%) 0 0 0);
    background:
      radial-gradient(ellipse at 74% 32%, var(--salt-grain-a), transparent 54%),
      radial-gradient(ellipse at 24% 72%, var(--salt-grain-b), transparent 46%),
      linear-gradient(126deg, transparent 8%, color-mix(in srgb, var(--salt-text) 6%, transparent) 34%, transparent 62%);
    mask-image: radial-gradient(ellipse at 70% 40%, black 0 34%, transparent 72%);
    pointer-events: none;
  }

  .salt-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(22rem, 1.14fr);
    gap: clamp(2rem, 7vw, 8rem);
    align-items: center;
  }

  .eyebrow-line { color: var(--salt-accent); }

  .salt-heading-stack {
    display: flex;
    flex-direction: column;
    gap: clamp(3.2rem, 6vw, 6rem);
    max-width: 46rem;
  }

  h2 {
    margin: 0;
    color: var(--salt-text);
    font-size: clamp(3rem, 7vw, 6.5rem);
  }

  .salt-text {
    max-width: 42rem;
    margin: 0;
    color: var(--salt-text);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    line-height: 1.58;
  }

  .salt-plates {
    position: relative;
    min-height: 35rem;
  }

  .plate {
    position: absolute;
    object-fit: cover;
    border-radius: 50%;
    box-shadow: 0 2rem 5rem rgba(0, 0, 0, 0.5);
  }

  .plate-one {
    width: min(38vw, 18rem);
    left: 0;
    top: 0;
  }
  .plate-two {
    width: min(44vw, 25rem);
    right: 3%;
    top: 21%;
  }
  .plate-three {
    width: min(34vw, 16rem);
    left: 12%;
    bottom: 0;
  }

  @media (max-width: 900px) {
    .salt-inner { grid-template-columns: 1fr; }
    .salt-plates { min-height: 28rem; }
    .plate-one { width: 13rem; }
    .plate-two { width: 17rem; }
    .plate-three { width: 12rem; }
  }
</style>
