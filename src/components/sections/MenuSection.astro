---
import type { MenuCategory } from '../../data/menu';

interface Props {
  category: MenuCategory;
  index: number;
}

const { category, index } = Astro.props;
---

<section class={`menu-category ${index % 2 ? 'is-reverse' : ''}`} id={category.id}>
  <img class="menu-depth menu-depth-rosemary" src="/assets/decor/rosemary.svg" alt="" aria-hidden="true" loading="lazy" />
  <img class="menu-depth menu-depth-spoon" src="/assets/decor/spoon.svg" alt="" aria-hidden="true" loading="lazy" />
  <img class="menu-depth menu-depth-tomato" src="/assets/decor/tomato.svg" alt="" aria-hidden="true" loading="lazy" />
  <div class="category-image" data-reveal={index % 2 ? 'right' : 'left'} data-scroll-rotate={String(8 + index * 2)} data-scroll-direction={index % 2 ? 'reverse' : 'normal'}>
    <img src={category.image} alt={category.imageAlt} loading="lazy" />
  </div>

  <div class="category-copy" data-reveal={index % 2 ? 'left' : 'right'}>
    <p class="category-number">0{index + 1}</p>
    <h2>{category.title}</h2>
    <p class="category-subtitle">{category.subtitle}</p>
    <div class="category-items">
      {category.items.map((item, itemIndex) => {
        const detailId = `${category.id}-dish-${itemIndex}`;
        return (
        <article class="menu-dish" data-menu-dish data-reveal="up" data-reveal-delay={String(120 + itemIndex * 90)}>
          <button class="dish-toggle" type="button" aria-expanded="false" aria-controls={detailId} data-dish-toggle>
            <span class="dish-main">
              <span class="dish-title">{item.name}</span>
              <span class="dish-description">{item.description}</span>
            </span>
            <span class="dish-side">
              <strong>{item.price}</strong>
              <svg class="dish-chevron" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
                <path d="m4.5 6.75 4.5 4.5 4.5-4.5" />
              </svg>
            </span>
          </button>
          {item.details && (
            <div class="dish-details" id={detailId} hidden data-dish-details>
              <div class="detail-stats">
                <span>{item.details.weight}</span>
                <span>{item.details.calories}</span>
                <span>Б {item.details.protein}</span>
                <span>Ж {item.details.fat}</span>
                <span>У {item.details.carbs}</span>
              </div>
              <div class="detail-grid">
                <p><b>Состав</b>{item.details.composition}</p>
                <p><b>Аллергены</b>{item.details.allergens}</p>
                <p><b>Вино</b>{item.details.winePairing}</p>
                <p><b>Подача</b>{item.details.cookTime}</p>
              </div>
              {item.details.tags && (
                <div class="detail-tags">
                  {item.details.tags.map((tag) => <span>{tag}</span>)}
                </div>
              )}
            </div>
          )}
        </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .menu-category {
    position: relative;
    display: grid;
    grid-template-columns: minmax(16rem, 0.78fr) minmax(0, 1.22fr);
    gap: clamp(2rem, 7vw, 8rem);
    align-items: center;
    padding-block: clamp(3rem, 8vw, 6rem);
    border-top: 1px solid var(--menu-border);
  }

  .menu-category.is-reverse {
    grid-template-columns: minmax(0, 1.22fr) minmax(16rem, 0.78fr);
  }

  .is-reverse .category-image { order: 2; }
  .is-reverse .category-copy { order: 1; }

  .category-image {
    position: relative;
    aspect-ratio: 1;
    width: min(100%, 25rem);
    margin-inline: auto;
  }

  .category-image::before {
    content: '';
    position: absolute;
    inset: 9%;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.42);
    filter: blur(28px);
    transform: translateY(12%);
  }

  .category-image img {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    box-shadow: 0 2rem 5rem rgba(0, 0, 0, 0.56);
    transition: transform 700ms var(--ease-out);
  }

  .category-image:hover img {
    transform: scale(1.035) rotate(1.3deg);
  }

  .category-number {
    margin: 0;
    color: var(--menu-accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
  }

  h2 {
    margin: 0.3rem 0 0;
    color: var(--menu-fg);
    font-size: clamp(3.2rem, 8vw, 7rem);
  }

  h2::after {
    content: '';
    display: block;
    width: clamp(4rem, 9vw, 7rem);
    height: 1px;
    margin-top: 0.8rem;
    background: var(--menu-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1100ms var(--ease-out);
  }

  .category-copy.is-visible h2::after,
  .category-copy[data-reveal].is-visible h2::after {
    transform: scaleX(1);
  }

  .category-subtitle {
    max-width: 37rem;
    margin: 1rem 0 1.5rem;
    color: var(--menu-muted);
  }

  .menu-dish {
    border-top: 1px solid var(--menu-border-soft);
    transition: border-color 220ms ease;
  }

  .dish-toggle {
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: start;
    border: 0;
    background: transparent;
    padding: 1.15rem 0;
    color: inherit;
    text-align: left;
  }

  .dish-toggle:hover,
  .dish-toggle:focus-visible {
    outline: none;
  }

  .menu-dish:hover,
  .menu-dish.is-open {
    border-color: color-mix(in srgb, var(--menu-accent) 46%, var(--menu-border-soft));
  }

  .dish-main {
    min-width: 0;
    display: grid;
    gap: 0.45rem;
  }

  .dish-side {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .dish-title {
    color: var(--menu-fg);
    font-family: 'Manrope', sans-serif;
    font-size: clamp(1rem, 1.7vw, 1.15rem);
    font-weight: 700;
    line-height: 1.35;
  }

  .dish-description {
    color: var(--menu-muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  strong {
    color: var(--menu-accent);
    white-space: nowrap;
    transition: transform 260ms ease, opacity 260ms ease;
  }

  .dish-chevron {
    color: var(--menu-muted);
    transition: transform 260ms ease, color 260ms ease;
  }

  .menu-dish.is-open .dish-chevron {
    color: var(--menu-accent);
    transform: rotate(180deg);
  }

  .menu-dish:hover strong,
  .menu-dish.is-open strong {
    transform: translateX(-0.25rem);
  }

  .dish-details {
    display: grid;
    gap: 1rem;
    overflow: hidden;
    padding: 0 0 1.2rem;
    color: var(--menu-muted);
    animation: details-open 340ms var(--ease-out) both;
  }

  .detail-stats,
  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .detail-stats span,
  .detail-tags span {
    border: 1px solid var(--menu-border-soft);
    border-radius: 999px;
    padding: 0.42rem 0.7rem;
    background: var(--menu-chip-bg);
    color: var(--menu-fg);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem 1.2rem;
  }

  .detail-grid p {
    margin: 0;
    color: var(--menu-muted);
    font-size: 0.86rem;
    line-height: 1.55;
  }

  .detail-grid b {
    display: block;
    margin-bottom: 0.15rem;
    color: var(--menu-fg);
    font-size: 0.68rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .menu-depth {
    position: absolute;
    pointer-events: none;
    object-fit: contain;
    opacity: var(--depth-opacity, 0.52);
    animation: menu-depth-float 9s ease-in-out infinite;
  }

  .menu-depth-rosemary {
    right: 2%;
    top: 12%;
    width: clamp(7rem, 10vw, 10rem);
    height: auto;
    transform: rotate(42deg);
    z-index: -1;
    opacity: calc(var(--depth-opacity, 0.52) * 0.9);
    filter: blur(0.35px) drop-shadow(0 1rem 1.8rem rgba(0, 0, 0, 0.14));
  }

  .menu-depth-spoon {
    left: 3%;
    bottom: 8%;
    width: clamp(2.4rem, 4vw, 3.3rem);
    height: auto;
    transform: rotate(-23deg);
    filter: blur(0.3px) drop-shadow(0 1rem 1.8rem rgba(0, 0, 0, 0.18));
    z-index: 0;
    animation-delay: -3s;
  }

  .menu-depth-tomato {
    right: 16%;
    bottom: 16%;
    width: clamp(1.5rem, 2.3vw, 2.2rem);
    height: auto;
    filter: drop-shadow(0 1rem 2rem rgba(0, 0, 0, 0.18));
    z-index: 2;
    animation-delay: -5s;
  }

  :global([data-theme="dark"]) .menu-depth-rosemary,
  :global([data-theme="dark"]) .menu-depth-spoon {
    filter: invert(1) sepia(0.14) saturate(0.55) opacity(0.72) drop-shadow(0 1rem 1.8rem rgba(0, 0, 0, 0.3));
  }

  @keyframes details-open {
    from { opacity: 0; transform: translateY(-0.5rem); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes menu-depth-float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -0.65rem; }
  }

  @media (max-width: 860px) {
    .menu-category,
    .menu-category.is-reverse { grid-template-columns: 1fr; }
    .is-reverse .category-image,
    .is-reverse .category-copy { order: initial; }
    .category-image { width: min(100%, 18rem); }
    .dish-toggle { gap: 1rem; }
    .menu-depth-spoon,
    .menu-depth-rosemary { display: none; }
  }

  @media (max-width: 540px) {
    .dish-toggle,
    .detail-grid {
      grid-template-columns: 1fr;
    }

    .dish-side {
      width: 100%;
      justify-content: space-between;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-depth,
    .dish-details,
    .category-image img,
    h2::after {
      animation: none;
      transition: none;
    }
  }
</style>

<script>
  function initMenuDishes() {
    document.querySelectorAll<HTMLElement>('[data-menu-dish]').forEach((dish) => {
      if (dish.dataset.dishReady === 'true') return;
      dish.dataset.dishReady = 'true';

      const toggle = dish.querySelector<HTMLButtonElement>('[data-dish-toggle]');
      const details = dish.querySelector<HTMLElement>('[data-dish-details]');
      if (!toggle || !details) return;

      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        dish.classList.toggle('is-open', !expanded);
        details.hidden = expanded;
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMenuDishes, { once: true });
  } else {
    initMenuDishes();
  }
  document.addEventListener('astro:page-load', initMenuDishes);
</script>
