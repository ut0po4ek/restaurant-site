---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import { menuCategories } from '../../data/menu';
import basilDecor from '../../assets/decor/realistic/basil-leaves.png';
import spiceDecor from '../../assets/decor/realistic/spice-spoons.png';

const previewCategories = menuCategories.slice(0, 4).map((category) => ({
  ...category,
  items: category.items.slice(0, 3),
}));

---

<section id="menu-preview" class="menu-preview section-padding">
  <Image class="menu-preview-decor decor-real-herb" src={basilDecor} alt="" aria-hidden="true" loading="lazy" />
  <Image class="menu-preview-decor decor-real-spice" src={spiceDecor} alt="" aria-hidden="true" loading="lazy" />
  <div class="container-site">
    <div class="menu-head">
      <img class="menu-head-herb" src="/assets/decor/rosemary.svg" alt="" aria-hidden="true" loading="lazy" />
      <div class="menu-head-text">
        <span class="eyebrow-line" data-reveal="up">Меню</span>
        <h2 data-reveal="up" data-reveal-delay="120">Соль, огонь<br />и глубокий вечерний фон</h2>
        <p data-reveal="up" data-reveal-delay="320">
          Меню построено вокруг свежих ингредиентов, открытого огня и классических итальянских сочетаний. На тёмном фоне вкус становится точнее: хруст хлеба, дым гриля, плотность соуса и тихий блеск бокала.
        </p>
      </div>
    </div>

    <div class="preview-list">
      {previewCategories.map((category, index) => (
        <article data-reveal="up" data-reveal-delay={String(80 + index * 110)}>
          <div class="category-header">
            <div class="category-title-block">
              <h3>{category.title}</h3>
              <span class="category-subtitle">{category.subtitle}</span>
            </div>
          </div>
          <div class="category-items">
            {category.items.map((item) => (
              <div class="menu-row">
                <div>
                  <h4>{item.name}</h4>
                  <p>{item.description}</p>
                </div>
                <strong>{item.price}</strong>
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>

    <div class="menu-action" data-reveal="up">
      <Button href="/menu" variant="accent" size="lg">Открыть полное меню</Button>
    </div>
  </div>
</section>

<style>
  .menu-preview {
    position: relative;
    overflow: hidden;
    background: var(--color-bg-warm);
  }

  .menu-preview-decor {
    position: absolute;
    pointer-events: none;
    height: auto;
    object-fit: contain;
    opacity: 0.38;
    filter: saturate(1.05) contrast(1.04) drop-shadow(0 1.4rem 2.4rem rgba(25, 23, 21, 0.18));
    animation: menu-preview-float 10s ease-in-out infinite;
  }

  .decor-real-herb {
    right: max(1rem, calc((100vw - 1440px) / 2 + 2rem));
    top: 7%;
    width: clamp(5rem, 8.5vw, 7.5rem);
    transform: rotate(15deg);
  }

  .decor-real-spice {
    left: max(1rem, calc((100vw - 1440px) / 2 + 2.5rem));
    bottom: 6%;
    width: clamp(5.5rem, 9vw, 8rem);
    transform: rotate(-18deg);
    animation-delay: -4.5s;
  }

  :global([data-theme="dark"]) .menu-preview-decor {
    opacity: 0.46;
    filter: saturate(0.88) brightness(0.84) contrast(1.08) drop-shadow(0 0 1.4rem rgba(246, 239, 228, 0.12)) drop-shadow(0 1.4rem 2.4rem rgba(0, 0, 0, 0.32));
  }

  @keyframes menu-preview-float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -0.55rem; }
  }

  .menu-head {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: clamp(1.4rem, 6vw, 5rem);
    margin-bottom: clamp(2.5rem, 6vw, 4.5rem);
  }

  .menu-head-herb {
    position: absolute;
    pointer-events: none;
    right: clamp(0rem, 6vw, 5rem);
    top: -2rem;
    z-index: 0;
    width: clamp(4.8rem, 8vw, 7.5rem);
    height: auto;
    opacity: 0.22;
    transform: rotate(28deg);
    filter: drop-shadow(0 1rem 1.4rem rgba(25, 23, 21, 0.14));
  }

  :global([data-theme="dark"]) .menu-head-herb {
    filter: invert(1) sepia(0.16) saturate(0.55) opacity(0.7) drop-shadow(0 1.2rem 2rem rgba(0, 0, 0, 0.28));
  }

  .menu-head-text {
    max-width: 52rem;
  }

  .menu-head-text .eyebrow-line {
    display: block;
    margin-bottom: 0.9rem;
  }

  .menu-head-text h2 {
    margin: 0;
    font-size: clamp(2.6rem, 5.4vw, 5rem);
    line-height: 1.06;
  }

  .menu-head-text h2::after {
    content: '';
    display: block;
    width: clamp(3rem, 6vw, 5rem);
    height: 2px;
    margin-top: clamp(1rem, 2vw, 1.4rem);
    margin-bottom: clamp(1.1rem, 2.2vw, 1.6rem);
    background: var(--color-accent);
    border-radius: 999px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 900ms var(--ease-out);
  }

  .menu-head-text h2.is-visible::after,
  .menu-head-text [data-reveal].is-visible ~ * h2::after {
    transform: scaleX(1);
  }

  /* Trigger underline when h2 itself becomes visible */
  .menu-head-text h2[data-reveal].is-visible::after {
    transform: scaleX(1);
  }

  .menu-head-text p {
    max-width: 46rem;
    margin: 0;
    color: var(--color-fg-muted);
    line-height: 1.7;
  }

  .preview-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.8rem, 4.5vw, 3.5rem) clamp(2rem, 6vw, 5rem);
  }

  article {
    border-top: 2px solid var(--color-border);
    padding-top: 1.4rem;
    transition: border-color 280ms ease;
  }

  article:hover {
    border-top-color: var(--color-accent);
  }

  .category-header {
    margin-bottom: 1.2rem;
  }

  .category-title-block {
    min-width: 0;
  }

  h3 {
    margin: 0 0 0.3rem;
    font-size: clamp(1.8rem, 2.8vw, 2.8rem);
    line-height: 1.05;
  }

  .category-subtitle {
    display: block;
    color: var(--color-fg-muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .menu-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(1rem, 3vw, 1.5rem);
    padding: 1.1rem 0;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 60%, transparent);
  }

  .menu-row > div {
    min-width: 0;
  }

  h4 {
    margin: 0;
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .menu-row p {
    margin: 0.4rem 0 0;
    color: var(--color-fg-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  strong {
    color: var(--color-accent-dark);
    font-size: 0.95rem;
    white-space: nowrap;
    padding-top: 0.12rem;
    font-weight: 700;
  }

  :global([data-theme="dark"]) strong {
    color: var(--color-accent-dark);
  }

  .menu-action {
    margin-top: clamp(2rem, 5vw, 4rem);
  }

  @media (max-width: 900px) {
    .preview-list { grid-template-columns: 1fr; }
    .menu-head { flex-direction: column; gap: 0; }
  }

  @media (max-width: 540px) {
    .menu-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    strong { padding-top: 0; }
    .menu-preview-decor,
    .menu-head-herb { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-preview-decor { animation: none; }
    .menu-head-text h2::after { transition: none; }
  }
</style>
