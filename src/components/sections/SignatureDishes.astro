---
import { signatureDishes } from '../../data/menu';
---

<section class="signature-dishes section-padding">
  <div class="container-site">
    <div class="section-head">
      <span class="eyebrow-line" data-reveal="up">Фирменные блюда</span>
      <h2 data-reveal="up" data-reveal-delay="150">Тарелки, которые собирают вечер вокруг себя</h2>
    </div>

    <div class="dish-grid">
      {signatureDishes.map((dish, index) => (
        <article class="dish-card" data-reveal="up" data-reveal-delay={String(150 + index * 120)}>
          <div class="dish-visual" data-scroll-rotate={String(10 + index * 3)} data-scroll-direction={index % 2 ? 'reverse' : 'normal'}>
            <span class="dish-shadow"></span>
            <img class="dish-plate" src={dish.image} alt={dish.alt} loading="lazy" />
            <img class="dish-decor decor-rosemary" src="/assets/decor/rosemary.svg" alt="" aria-hidden="true" loading="lazy" />
            <img class="dish-decor decor-tomato" src="/assets/decor/tomato.svg" alt="" aria-hidden="true" loading="lazy" />
            <img class="dish-decor decor-pasta" src="/assets/decor/pasta.svg" alt="" aria-hidden="true" loading="lazy" />
            <img class="dish-decor decor-fork" src="/assets/decor/fork.svg" alt="" aria-hidden="true" loading="lazy" />
          </div>
          <div class="dish-copy">
            <p class="dish-index">0{index + 1}</p>
            <h3>{dish.name}</h3>
            <p>{dish.note}</p>
            <span>{dish.price}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .signature-dishes {
    background: var(--color-bg);
    overflow: hidden;
  }

  .section-head {
    display: grid;
    grid-template-columns: minmax(11rem, 0.4fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 7vw, 8rem);
    align-items: end;
    margin-bottom: clamp(2.5rem, 6vw, 5rem);
  }

  h2 {
    margin: 0;
    max-width: 55rem;
    font-size: clamp(3rem, 7vw, 6.7rem);
  }

  .dish-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.2rem, 3vw, 2.5rem);
  }

  .dish-card {
    position: relative;
    display: grid;
    align-content: start;
    min-height: 32rem;
    padding: clamp(1rem, 2.4vw, 1.5rem);
    border-top: 1px solid var(--color-border);
  }

  .dish-card:nth-child(2) { margin-top: 4rem; }
  .dish-card:nth-child(3) { margin-top: 1.5rem; }

  .dish-visual {
    position: relative;
    width: min(100%, 24rem);
    aspect-ratio: 1;
    margin-inline: auto;
    transform-origin: center;
  }

  .dish-shadow {
    position: absolute;
    inset: 11%;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.28);
    filter: blur(28px);
    transform: translateY(12%);
  }

  .dish-plate {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    box-shadow: 0 1.4rem 4rem rgba(25, 23, 21, 0.22);
  }

  .dish-decor {
    position: absolute;
    pointer-events: none;
    object-fit: contain;
    filter: drop-shadow(0 0.85rem 1.15rem rgba(25, 23, 21, 0.18));
    animation: dish-decor-float 8s ease-in-out infinite;
  }

  .decor-rosemary {
    z-index: 3;
    width: clamp(4.8rem, 8vw, 7.3rem);
    height: auto;
    right: 4%;
    top: 4%;
    opacity: 0.78;
    transform: rotate(34deg);
    filter: drop-shadow(0 1rem 1.25rem rgba(25, 23, 21, 0.22));
  }

  .decor-tomato {
    z-index: 3;
    width: clamp(1.9rem, 3vw, 2.6rem);
    height: auto;
    left: 8%;
    bottom: 17%;
    opacity: 0.9;
    animation-delay: -1.5s;
  }

  .decor-pasta {
    z-index: 0;
    width: clamp(4rem, 8vw, 6.2rem);
    height: auto;
    left: -2%;
    top: 22%;
    opacity: 0.72;
    filter: blur(0.2px) drop-shadow(0 0.9rem 1rem rgba(25, 23, 21, 0.16)) sepia(0.28) saturate(0.82);
    transform: rotate(-23deg);
    animation-delay: -3s;
  }

  .decor-fork {
    z-index: 0;
    right: -7%;
    bottom: 4%;
    width: clamp(2.2rem, 4vw, 3.1rem);
    height: auto;
    opacity: 0.38;
    transform: rotate(23deg);
    filter: blur(0.45px) drop-shadow(0 1rem 1.3rem rgba(25, 23, 21, 0.18));
    animation-delay: -4.4s;
  }

  :global([data-theme="dark"]) .decor-rosemary,
  :global([data-theme="dark"]) .decor-fork {
    filter: invert(1) sepia(0.18) saturate(0.55) opacity(0.72) drop-shadow(0 1rem 1.4rem rgba(0, 0, 0, 0.28));
  }

  :global([data-theme="dark"]) .decor-pasta {
    filter: invert(0.88) sepia(0.42) saturate(0.8) opacity(0.76) drop-shadow(0 1rem 1.4rem rgba(0, 0, 0, 0.28));
  }

  @keyframes dish-decor-float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -0.45rem; }
  }

  .dish-copy {
    position: relative;
    z-index: 3;
    margin-top: -1rem;
    padding: 1.2rem 0 0;
  }

  .dish-index {
    margin: 0 0 0.7rem;
    color: var(--color-accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
  }

  h3 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.2rem);
  }

  .dish-copy p:not(.dish-index) {
    margin: 0.8rem 0 1rem;
    color: var(--color-fg-muted);
    font-size: 0.96rem;
  }

  .dish-copy span {
    color: var(--color-fg);
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .section-head,
    .dish-grid { grid-template-columns: 1fr; }
    .dish-card,
    .dish-card:nth-child(2),
    .dish-card:nth-child(3) {
      min-height: auto;
      margin-top: 0;
    }
    .decor-fork,
    .decor-pasta { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .dish-decor { animation: none; }
  }
</style>
