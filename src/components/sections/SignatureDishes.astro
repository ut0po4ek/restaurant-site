---
import { signatureDishes } from '../../data/menu';
---

<section class="signature-dishes section-padding">
  <img
    class="signature-tomato-decor"
    src="/assets/decor/realistic/tomatoes-vine.png"
    alt=""
    aria-hidden="true"
    loading="lazy"
    data-parallax
    data-parallax-speed="0.028"
    data-parallax-rotate="-1.8"
  />
  <div class="container-site">
    <div class="section-head">
      <span class="eyebrow-line" data-reveal="up">Фирменные блюда</span>
      <h2 data-reveal="up" data-reveal-delay="150">Тарелки, которые собирают вечер вокруг себя</h2>
    </div>

    <div class="dish-grid">
      {signatureDishes.map((dish, index) => (
        <article class="dish-card" data-reveal="up" data-reveal-delay={String(150 + index * 120)}>
          <div class="dish-visual" data-scroll-rotate={String(10 + index * 3)} data-scroll-direction={index % 2 ? 'reverse' : 'normal'}>
            <span class="dish-shadow"></span>
            <img class="dish-plate" src={dish.image} alt={dish.alt} loading="lazy" />
          </div>
          <div class="dish-copy">
            <img class="dish-decor decor-rosemary" src="/assets/decor/rosemary.svg" alt="" aria-hidden="true" loading="lazy" />
            <p class="dish-index">0{index + 1}</p>
            <h3>{dish.name}</h3>
            <p>{dish.note}</p>
            <span>{dish.price}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .signature-dishes {
    position: relative;
    background: var(--color-bg);
    overflow: hidden;
  }

  .signature-tomato-decor {
    position: absolute;
    pointer-events: none;
    z-index: 0;
    left: max(0.5rem, calc((100vw - 1440px) / 2 + 1rem));
    top: 12%;
    width: clamp(6rem, 9.5vw, 9rem);
    height: auto;
    object-fit: contain;
    opacity: 0.36;
    filter: saturate(1.08) contrast(1.04) drop-shadow(0 1.2rem 2rem rgba(25,23,21,0.16));
    transform: translate3d(0, var(--parallax-y, 0px), 0) rotate(calc(-10deg + var(--parallax-rotate, 0deg)));
    animation: sig-tomato-float 13s ease-in-out infinite;
  }

  :global([data-theme="dark"]) .signature-tomato-decor {
    opacity: 0.28;
    filter: saturate(0.92) brightness(0.82) contrast(1.06) drop-shadow(0 0 1.2rem rgba(246,239,228,0.1)) drop-shadow(0 1rem 2rem rgba(0,0,0,0.34));
  }

  @keyframes sig-tomato-float {
    0%, 100% { translate: 0 0; }
    40% { translate: 0.4rem -0.9rem; }
    70% { translate: -0.2rem -0.5rem; }
  }

  .section-head {
    display: grid;
    grid-template-columns: minmax(11rem, 0.4fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 7vw, 8rem);
    align-items: end;
    margin-bottom: clamp(2.5rem, 6vw, 5rem);
  }

  h2 {
    margin: 0;
    max-width: 55rem;
    font-size: clamp(3rem, 7vw, 6.7rem);
  }

  .dish-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.2rem, 3vw, 2.5rem);
  }

  .dish-card {
    position: relative;
    display: grid;
    align-content: start;
    min-height: 32rem;
    padding: clamp(1rem, 2.4vw, 1.5rem);
    border-top: 1px solid var(--color-border);
  }

  .dish-card:nth-child(2) { margin-top: 4rem; }
  .dish-card:nth-child(3) { margin-top: 1.5rem; }

  .dish-visual {
    position: relative;
    width: min(100%, 24rem);
    aspect-ratio: 1;
    margin-inline: auto;
    transform-origin: center;
  }

  .dish-shadow {
    position: absolute;
    inset: 11%;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.28);
    filter: blur(28px);
    transform: translateY(12%);
  }

  .dish-plate {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    box-shadow: 0 1.4rem 4rem rgba(25, 23, 21, 0.22);
  }

  .dish-decor {
    position: absolute;
    pointer-events: none;
    object-fit: contain;
    z-index: -1;
    filter: drop-shadow(0 0.85rem 1.15rem rgba(25, 23, 21, 0.18));
    animation: dish-decor-float 8s ease-in-out infinite;
  }

  .decor-rosemary {
    width: clamp(4.3rem, 7vw, 6.3rem);
    height: auto;
    right: -0.7rem;
    top: -1.4rem;
    opacity: 0.46;
    transform: rotate(27deg);
    filter: drop-shadow(0 1rem 1.25rem rgba(25, 23, 21, 0.22));
  }

  :global([data-theme="dark"]) .decor-rosemary {
    filter: invert(1) sepia(0.18) saturate(0.55) opacity(0.72) drop-shadow(0 1rem 1.4rem rgba(0, 0, 0, 0.28));
  }

  @keyframes dish-decor-float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -0.45rem; }
  }

  .dish-copy {
    position: relative;
    z-index: 3;
    margin-top: -1rem;
    padding: 1.2rem 0 0;
  }

  .dish-index {
    margin: 0 0 0.7rem;
    color: var(--color-accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
  }

  h3 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.2rem);
  }

  .dish-copy p:not(.dish-index) {
    margin: 0.8rem 0 1rem;
    color: var(--color-fg-muted);
    font-size: 0.96rem;
  }

  .dish-copy span {
    color: var(--color-fg);
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .section-head,
    .dish-grid { grid-template-columns: 1fr; }
    .dish-card,
    .dish-card:nth-child(2),
    .dish-card:nth-child(3) {
      min-height: auto;
      margin-top: 0;
    }
    .decor-rosemary {
      right: 0;
      top: -0.8rem;
      width: clamp(3.7rem, 16vw, 5.2rem);
      opacity: 0.34;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dish-decor { animation: none; }
  }
</style>
